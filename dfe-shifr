        function exportAllData() {
            const exportData = {
                version: '3.0',
                timestamp: new Date().toISOString(),
                dictionaries: {
                    ruToDfe: ruToDfe,
                    enToDfe: enToDfe,
                    digitsToDfe: digitsToDfe,
                    symbolsToDfe: symbolsToDfe
                },
                state: {
                    history: state.history,
                    stats: state.stats,
                    lang: state.lang,
                    theme: state.theme,
                    user: state.user,
                    settings: state.settings
                }
            };
            
            const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
