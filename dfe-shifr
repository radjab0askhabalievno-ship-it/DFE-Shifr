        function bulkConvert(direction) {
            const input = document.getElementById('bulkInput').value;
            const lines = input.split('\n').filter(line => line.trim() !== '');
            
            if (lines.length === 0) {
                toast('⚠ No lines to convert');
                return;
            }
            
            const results = lines.map((line, index) => {
                const trimmed = line.trim();
                if (direction === 'encode') {
                    const result = encodeText(trimmed);
                    return result.error ? 'ERR[' + (index + 1) + ']: ' + result.error : result.result;
                } else {
                    const result = decodeText(trimmed);
                    return result.error ? 'ERR[' + (index + 1) + ']: ' + result.error : result.result;
                }
            });
            
            document.getElementById('bulkOutput').value = results.join('\n');
            toast('✅ Bulk ' + direction + ' completed: ' + lines.length + ' lines');
        }
        
        // ============================================================
        // SECTION 7: COMPARISON & ANALYSIS
        // ============================================================
        function runComparison() {
            const original = document.getElementById('compareOriginal').value.trim();
            const cipher = document.getElementById('compareCipher').value.trim();
            const resultPanel = document.getElementById('compareResultPanel');
            
            if (!original || !cipher) {
                resultPanel.innerHTML = '<span style="color:var(--red);">Please enter both original text and cipher.</span>';
                return;
            }
            
            const encoded = encodeText(original);
            const decoded = decodeText(cipher);
            
            let html = '<div style="line-height:1.8;">';
            
            // Check if cipher matches
            if (encoded.result === cipher) {
                html += '<span style="color:var(--green);">✅ Original → Cipher: MATCH</span><br>';
            } else {
                html += '<span style="color:var(--red);">❌ Original → Cipher: MISMATCH</span><br>';
                html += '<small>Expected: ' + escapeHtml(encoded.result.slice(0, 60)) + '...</small><br>';
            }
            
            // Check if decode matches
            if (decoded.result === original.toUpperCase()) {
                html += '<span style="color:var(--green);">✅ Cipher → Original: MATCH</span><br>';
            } else {
                html += '<span style="color:var(--red);">❌ Cipher → Original: MISMATCH</span><br>';
                html += '<small>Got: ' + escapeHtml((decoded.result || '').slice(0, 60)) + '...</small><br>';
            }
            
            // Stats
            html += '<br><b>Stats:</b><br>';
            html += 'Original length: ' + original.length + ' chars<br>';
            html += 'Cipher length: ' + cipher.length + ' chars<br>';
            html += 'Ratio: ' + (original.length > 0 ? (cipher.length / original.length).toFixed(2) : 'N/A') + 'x<br>';
            
            html += '</div>';
            resultPanel.innerHTML = html;
        }
        
        function analyzeCipher() {
            const input = document.getElementById('analyzeInput').value.trim();
            const resultDiv = document.getElementById('analyzeResult');
            
            if (!input) {
                resultDiv.innerHTML = '<span style="color:var(--red);">Please paste DFE! cipher to analyze.</span>';
                return;
            }
            
            // Count codes
            const codeCounts = {};
            let remaining = input;
            let decoded = '';
            let failsafe = 0;
            
            while (remaining.length > 0 && failsafe < 10000) {
                failsafe++;
                let found = false;
                for (const code of sortedCodes) {
                    if (remaining.startsWith(code)) {
                        const char = dfeToChar[code];
                        codeCounts[code] = (codeCounts[code] || 0) + 1;
                        decoded += char;
                        remaining = remaining.slice(code.length);
                        found = true;
                        break;
                    }
                }
                if (!found) {
                    remaining = remaining.slice(1);
                }
            }
            
            const totalCodes = Object.values(codeCounts).reduce((a, b) => a + b, 0);
            const uniqueCodes = Object.keys(codeCounts).length;
            
            let html = '<div style="line-height:1.6;">';
            html += '<b>📊 Analysis Results:</b><br>';
            html += 'Decoded text: ' + escapeHtml(decoded.slice(0, 100)) + (decoded.length > 100 ? '...' : '') + '<br>';
            html += 'Total codes found: ' + totalCodes + '<br>';
            html += 'Unique code types: ' + uniqueCodes + '<br>';
            html += 'Decoded characters: ' + decoded.length + '<br>';
            html += '<br><b>Most used codes:</b><br>';
            
            const sorted = Object.entries(codeCounts).sort((a, b) => b[1] - a[1]).slice(0, 10);
            sorted.forEach(([code, count]) => {
                const char = dfeToChar[code] || '?';
                html += escapeHtml(code) + ' → "' + char + '" used ' + count + ' times<br>';
            });
            
            html += '</div>';
            resultDiv.innerHTML = html;
        }
        
