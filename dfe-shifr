        // ============================================================
        // SECTION 4: ENCODING / DECODING ENGINE
        // ============================================================
        function encodeText(text) {
            const upper = text.toUpperCase();
            let result = '';
            let unknownChars = [];
            
            for (const char of upper) {
                if (allToDfe[char] !== undefined) {
                    result += allToDfe[char];
                } else {
                    unknownChars.push(char);
                    result += '[?' + char + ']';
                }
            }
            
            if (unknownChars.length > 0) {
                const unique = [...new Set(unknownChars)];
                return {
                    result: result,
                    warning: '⚠ Skipped unknown characters: ' + unique.join(' ')
                };
            }
            
            return { result: result };
        }
        
        function decodeText(dfeString) {
            let remaining = dfeString;
            let result = '';
            let attempts = 0;
            const maxAttempts = 50000;
            
            while (remaining.length > 0 && attempts < maxAttempts) {
                attempts++;
                let found = false;
                
                for (const code of sortedCodes) {
                    if (remaining.startsWith(code)) {
                        result += dfeToChar[code];
                        remaining = remaining.slice(code.length);
                        found = true;
                        break;
                    }
                }
                
                if (!found) {
                    // Try to handle unknown codes gracefully
                    const snippet = remaining.slice(0, 12);
                    state.stats.errors++;
                    updateStatsDisplay();
                    return {
                        error: '❌ Cannot decode at: "' + snippet + '..."',
                        partial: result || '(empty)'
                    };
                }
            }
            
            if (attempts >= maxAttempts) {
                return { error: '❌ Decoding loop limit reached. Input may be too long or corrupted.' };
            }
            
            return { result: result };
        }
        
        function performConversion(direction) {
            clearErrors();
            
            if (direction === 'encode') {
                const input = document.getElementById('plainInput').value;
                if (!input.trim()) {
                    showError('plainError', 'Please enter text to encrypt.');
                    return null;
                }
                
                const startTime = performance.now();
                const result = encodeText(input);
                const elapsed = performance.now() - startTime;
                
                if (result.error) {
                    showError('plainError', result.error);
                    return null;
                }
                
                document.getElementById('dfeOutput').value = result.result;
                if (result.warning) {
                    showError('plainError', result.warning);
                }
                
                state.stats.encrypted++;
                state.stats.totalChars += input.length;
                updateStatsDisplay();
                updateCharacterCounts();
                
                return {
                    dir: '→',
                    from: input,
                    to: result.result,
                    time: elapsed.toFixed(1) + 'ms'
                };
                
            } else {
                const input = document.getElementById('dfeOutput').value;
                if (!input.trim()) {
                    showError('dfeError', 'Please enter DFE! cipher to decrypt.');
                    return null;
                }
                
                const startTime = performance.now();
                const result = decodeText(input);
                const elapsed = performance.now() - startTime;
                
                if (result.error) {
                    showError('dfeError', result.error);
                    return null;
                }
                
                document.getElementById('plainInput').value = result.result;
                state.stats.decrypted++;
                state.stats.totalChars += result.result.length;
                updateStatsDisplay();
                updateCharacterCounts();
                
                return {
                    dir: '←',
                    from: input,
                    to: result.result,
                    time: elapsed.toFixed(1) + 'ms'
                };
            }
        }
        
        function performEncode() {
            state.mode = 'encode';
            updateModeBadge();
            const result = performConversion('encode');
            if (result) {
                addToHistory(result);
