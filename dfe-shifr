<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DFE! Ultimate Converter</title>
    <style>
        /* ============================================================
           DFE! ULTIMATE STYLES - COMPLETE DESIGN SYSTEM
           ============================================================ */
        :root {
            --bg: #0a0e14;
            --bg2: #0d1117;
            --panel: #131820;
            --panel2: #161b22;
            --border: #1e2733;
            --border2: #30363d;
            --text: #c9d1d9;
            --text2: #8b949e;
            --accent: #ff6b35;
            --accent2: #ff8c5a;
            --green: #3fb950;
            --green2: #2ea043;
            --red: #f85149;
            --red2: #da3633;
            --yellow: #f0c040;
            --yellow2: #d2991d;
            --purple: #a371f7;
            --purple2: #8250df;
            --pink: #ff6b9d;
            --pink2: #e0558a;
            --cyan: #39d2c0;
            --cyan2: #2aa89a;
            --font: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
            --shadow-md: 0 4px 12px rgba(0,0,0,0.4);
            --shadow-lg: 0 8px 24px rgba(0,0,0,0.5);
            --shadow-glow: 0 0 20px rgba(255,107,53,0.2);
            --shadow-glow-lg: 0 0 40px rgba(255,107,53,0.3);
            --radius-sm: 4px;
            --radius-md: 8px;
            --radius-lg: 12px;
            --radius-xl: 16px;
            --radius-full: 9999px;
            --transition-fast: 0.15s ease;
            --transition: 0.25s ease;
            --transition-slow: 0.4s ease;
        }
        body.light {
            --bg: #f0f2f5;
            --bg2: #e8eaed;
            --panel: #ffffff;
            --panel2: #f6f8fa;
            --border: #d0d7de;
            --border2: #afb8c1;
            --text: #1a1a2e;
            --text2: #656d76;
            --accent: #e65100;
            --accent2: #ff6b35;
            --shadow-glow: 0 0 20px rgba(230,81,0,0.15);
            --shadow-glow-lg: 0 0 40px rgba(230,81,0,0.25);
        }
        
        /* ========== RESET & BASE ========== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            transition: background var(--transition), color var(--transition);
            overflow-x: hidden;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        ::selection { background: var(--accent); color: #fff; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: var(--radius-full); }
        ::-webkit-scrollbar-thumb:hover { background: var(--border2); }
        
        /* ========== PARTICLE BACKGROUND ========== */
        #particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .particle {
            position: absolute;
            width: 3px;
            height: 3px;
            background: var(--accent);
            border-radius: 50%;
            animation: particleFloat 8s infinite ease-in-out;
            opacity: 0;
        }
        .particle:nth-child(odd) { width: 2px; height: 2px; background: var(--cyan); animation-duration: 10s; }
        .particle:nth-child(3n) { width: 4px; height: 4px; background: var(--purple); animation-duration: 12s; }
        .particle:nth-child(5n) { background: var(--pink); animation-duration: 7s; }
        @keyframes particleFloat {
            0% { transform: translateY(0) translateX(0) rotate(0deg); opacity: 0; }
            10% { opacity: 0.4; }
            90% { opacity: 0.4; }
            100% { transform: translateY(-60px) translateX(30px) rotate(360deg); opacity: 0; }
        }
        
        /* ========== MAIN APP CONTAINER ========== */
        .app {
            position: relative;
            z-index: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 12px 16px;
        }
        
        /* ========== DONATE BAR ========== */
        .donate-bar {
            background: linear-gradient(135deg, #ff6b35 0%, #f0c040 50%, #ff6b35 100%);
            background-size: 200% 200%;
            animation: gradientShift 3s ease infinite;
            color: #000;
            padding: 10px 18px;
            border-radius: var(--radius-lg);
            margin-bottom: 10px;
            font-size: 11px;
            font-weight: 700;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            box-shadow: var(--shadow-md);
            position: sticky;
            top: 10px;
            z-index: 50;
        }
        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        .donate-bar .bal-info { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
        .donate-bar .bal-item { display: flex; align-items: center; gap: 4px; }
        .donate-bar .btn { background: #000; color: #fff; border: 2px solid #000; font-size: 10px; padding: 6px 12px; }
        .donate-bar .btn:hover { background: #fff; color: #000; }
        
        /* ========== TOP BAR ========== */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            padding: 10px 18px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            margin-bottom: 10px;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 60px;
            z-index: 40;
        }
        .logo {
            font-size: 24px;
            font-weight: 900;
            color: var(--accent);
            cursor: pointer;
            user-select: none;
            letter-spacing: 4px;
            text-shadow: 0 0 15px var(--accent), 0 0 30px var(--accent);
            transition: all var(--transition);
            position: relative;
        }
        .logo:hover {
            text-shadow: 0 0 25px var(--accent), 0 0 50px var(--accent), 0 0 75px var(--accent);
            transform: scale(1.03);
        }
        .logo:active { transform: scale(0.95); }
        .topbar-btns { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
        
        /* ========== BUTTON STYLES ========== */
        .btn {
            padding: 8px 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            background: var(--panel);
            color: var(--text);
            cursor: pointer;
            font-size: 11px;
            font-weight: 600;
            font-family: var(--font);
            transition: all var(--transition);
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            letter-spacing: 0.5px;
        }
        .btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .btn:active { transform: translateY(0); }
        .btn.accent { background: var(--accent); color: #fff; border-color: var(--accent); }
        .btn.accent:hover { box-shadow: var(--shadow-glow-lg); background: var(--accent2); }
        .btn.success { color: var(--green); border-color: var(--green); }
        .btn.success:hover { background: #3fb95015; }
        .btn.danger { color: var(--red); border-color: var(--red); }
        .btn.danger:hover { background: #da363315; }
        .btn.warning { color: var(--yellow); border-color: var(--yellow); }
        .btn.warning:hover { background: #f0c04015; }
        .btn.purple { color: var(--purple); border-color: var(--purple); }
        .btn.purple:hover { background: #a371f715; }
        .btn-sm {
            padding: 4px 10px;
            font-size: 10px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            cursor: pointer;
            font-family: var(--font);
            transition: all var(--transition-fast);
            white-space: nowrap;
        }
        .btn-sm:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }
        .btn-sm.active { background: var(--accent); color: #fff; border-color: var(--accent); }
        
        /* ========== BADGES ========== */
        .badge {
            padding: 4px 10px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: 700;
            font-family: var(--font);
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 3px;
        }
        .badge-info { background: #58a6ff18; color: #58a6ff; border: 1px solid #58a6ff40; }
        .badge-success { background: #3fb95018; color: var(--green); border: 1px solid #3fb95040; }
        .badge-warning { background: #f0c04018; color: var(--yellow); border: 1px solid #f0c04040; }
        .badge-danger { background: #f8514918; color: var(--red); border: 1px solid #f8514940; }
        .badge-accent { background: #ff6b3518; color: var(--accent); border: 1px solid #ff6b3540; }
        
        /* ========== MAIN LAYOUT ========== */
        .main-layout { display: flex; gap: 12px; align-items: flex-start; }
        
        /* ========== SIDEBAR ========== */
        .sidebar {
            width: 220px;
            min-width: 200px;
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 14px 10px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 120px;
            max-height: calc(100vh - 140px);
            overflow-y: auto;
        }
        .sidebar .user-card {
            text-align: center;
            padding: 10px;
            background: var(--bg);
            border-radius: var(--radius-md);
            margin-bottom: 8px;
        }
        .sidebar .avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--purple));
            margin: 0 auto 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: var(--shadow-glow);
        }
        .sidebar .username { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
        .sidebar .user-level { font-size: 9px; color: var(--text2); }
        .sidebar .user-balance { font-size: 10px; color: var(--yellow); font-weight: 600; margin-top: 4px; }
        .sidebar .divider { border-top: 1px solid var(--border); margin: 6px 0; }
        .sidebar .nav-btn {
            width: 100%;
            padding: 8px 12px;
            text-align: left;
            background: transparent;
            border: 1px solid transparent;
            color: var(--text);
            cursor: pointer;
            font-size: 11px;
            font-family: var(--font);
            border-radius: var(--radius-md);
            transition: all var(--transition-fast);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .sidebar .nav-btn:hover { background: var(--bg); border-color: var(--border); color: var(--accent); }
        .sidebar .nav-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); font-weight: 700; }
        
        /* ========== CONTENT AREA ========== */
        .content { flex: 1; min-width: 0; }
        
        /* ========== TABS ========== */
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 12px;
            flex-wrap: wrap;
            background: var(--panel);
            border-radius: var(--radius-lg);
            padding: 4px;
            border: 1px solid var(--border);
        }
        .tabs button {
            padding: 8px 16px;
            border: 1px solid transparent;
            border-radius: var(--radius-md);
            background: transparent;
            color: var(--text2);
            cursor: pointer;
            font-size: 11px;
            font-family: var(--font);
            font-weight: 500;
            transition: all var(--transition);
            flex: 1;
            min-width: 80px;
            text-align: center;
        }
        .tabs button:hover { color: var(--text); background: var(--bg); }
        .tabs button.active {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
            font-weight: 700;
            box-shadow: var(--shadow-glow);
        }
        .tab-content { display: none; animation: tabFadeIn 0.35s ease; }
        .tab-content.active { display: block; }
        @keyframes tabFadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* ========== PANELS ========== */
        .panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 16px;
            margin-bottom: 10px;
            position: relative;
            transition: all var(--transition);
            box-shadow: var(--shadow-sm);
        }
        .panel:hover { border-color: var(--border2); box-shadow: var(--shadow-md); }
        .panel .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .panel label {
            display: block;
            color: var(--text2);
            margin-bottom: 6px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
        }
        .panel .panel-actions { display: flex; gap: 4px; position: absolute; top: 14px; right: 14px; }
        .panel .btn-icon {
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text2);
            padding: 4px 8px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 9px;
            font-family: var(--font);
            transition: all var(--transition-fast);
        }
        .panel .btn-icon:hover { border-color: var(--accent); color: var(--accent); background: var(--panel2); }
        
        /* ========== TEXTAREAS ========== */
        textarea {
            width: 100%;
            height: 110px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            color: var(--text);
            padding: 12px;
            font-family: var(--font);
            font-size: 13px;
            resize: vertical;
            outline: none;
            transition: all var(--transition);
            line-height: 1.6;
        }
        textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(255,107,53,0.1), var(--shadow-glow);
        }
        textarea::placeholder { color: var(--text2); opacity: 0.6; }
        .char-count {
            position: absolute;
            bottom: 8px;
            right: 14px;
            font-size: 9px;
            color: var(--text2);
            background: var(--bg);
            padding: 2px 8px;
            border-radius: var(--radius-full);
            pointer-events: none;
        }
        .error {
            color: var(--red);
            font-size: 10px;
            margin-top: 4px;
            min-height: 16px;
            font-weight: 600;
        }
        
        /* ========== BUTTON ROWS ========== */
        .btn-row {
            display: flex;
            gap: 6px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }
        
        /* ========== STATS ROW ========== */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 8px;
            margin-bottom: 10px;
        }
        .stat-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 12px 10px;
            text-align: center;
            font-size: 10px;
            color: var(--text2);
            transition: all var(--transition);
        }
        .stat-card:hover { border-color: var(--accent); }
        .stat-card .stat-val {
            font-size: 22px;
            font-weight: 900;
            color: var(--accent);
            display: block;
            margin-bottom: 2px;
        }
        .stat-card .stat-label { text-transform: uppercase; letter-spacing: 1px; }
        
        /* ========== HISTORY PANEL ========== */
        .history-panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 14px;
            box-shadow: var(--shadow-sm);
        }
        .history-panel h3 {
            color: var(--text2);
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .history-list { max-height: 180px; overflow-y: auto; }
        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
            font-size: 10px;
            gap: 8px;
            transition: background var(--transition-fast);
        }
        .history-item:hover { background: var(--bg); }
        .history-item:last-child { border-bottom: none; }
        .history-item .dir {
            color: var(--accent);
            font-weight: 700;
            font-size: 12px;
            min-width: 20px;
        }
        .history-item .text {
            flex: 1;
            word-break: break-all;
            color: var(--text);
        }
        .history-item .text small { color: var(--text2); display: block; font-size: 8px; }
        .history-item .act-btn {
            background: none;
            border: 1px solid var(--border);
            color: var(--text2);
            padding: 2px 6px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 9px;
            font-family: var(--font);
            transition: all var(--transition-fast);
            white-space: nowrap;
        }
        .history-item .act-btn:hover { border-color: var(--accent); color: var(--accent); }
        .history-item .act-btn.del:hover { border-color: var(--red); color: var(--red); }
        
        /* ========== MODAL SYSTEM ========== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.75);
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: modalFadeIn 0.2s ease;
            backdrop-filter: blur(4px);
        }
        @keyframes modalFadeIn { from { opacity: 0; } to { opacity: 1; } }
        .modal {
            background: var(--panel);
            border: 1px solid var(--border2);
            border-radius: var(--radius-xl);
            padding: 24px;
            max-width: 440px;
            width: 92%;
            text-align: center;
            box-shadow: var(--shadow-lg), var(--shadow-glow-lg);
            animation: modalSlideIn 0.3s ease;
        }
        @keyframes modalSlideIn { from { transform: translateY(-30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .modal h2 { color: var(--accent); margin-bottom: 14px; font-size: 18px; letter-spacing: 1px; }
        .modal p { font-size: 11px; color: var(--text2); margin-bottom: 8px; line-height: 1.6; }
        .modal input {
            width: 100%;
            padding: 10px 14px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            color: var(--text);
            font-family: var(--font);
            font-size: 13px;
            margin-bottom: 8px;
            outline: none;
            transition: all var(--transition);
        }
        .modal input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(255,107,53,0.1); }
        
        /* ========== TOAST SYSTEM ========== */
        .toast-container {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 300;
            display: flex;
            flex-direction: column;
            gap: 8px;
            pointer-events: none;
        }
        .toast {
            background: var(--panel);
            border: 1px solid var(--accent);
            color: var(--text);
            padding: 12px 18px;
            border-radius: var(--radius-md);
            font-size: 11px;
            font-family: var(--font);
            font-weight: 600;
            box-shadow: var(--shadow-lg);
            animation: toastSlideIn 0.35s ease;
            max-width: 340px;
            pointer-events: auto;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        @keyframes toastSlideIn {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .toast.removing { animation: toastSlideOut 0.3s ease forwards; }
        @keyframes toastSlideOut {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(120%); opacity: 0; }
        }
        
        /* ========== SPECIAL EFFECTS ========== */
        .glitch {
            animation: glitchEffect 0.4s linear;
        }
        @keyframes glitchEffect {
            0% { transform: translate(3px, 0) skew(0deg); filter: hue-rotate(0deg); }
            20% { transform: translate(-3px, 1px) skew(1deg); filter: hue-rotate(90deg); }
            40% { transform: translate(2px, -1px) skew(-1deg); filter: hue-rotate(180deg); }
            60% { transform: translate(-2px, 2px) skew(0.5deg); filter: hue-rotate(270deg); }
            80% { transform: translate(1px, -2px) skew(-0.5deg); filter: hue-rotate(360deg); }
            100% { transform: translate(0, 0) skew(0deg); filter: hue-rotate(0deg); }
        }
        .neon-text {
            text-shadow: 0 0 5px var(--accent), 0 0 10px var(--accent), 0 0 20px var(--accent), 0 0 40px var(--accent);
        }
        .shake {
            animation: shakeEffect 0.5s ease;
        }
        @keyframes shakeEffect {
            0%, 100% { transform: translateX(0); }
            10%, 50%, 90% { transform: translateX(-5px); }
            30%, 70% { transform: translateX(5px); }
        }
        
        /* ========== ACHIEVEMENT LIST ========== */
        .achievement-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 8px;
        }
        .achievement-card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 10px;
            text-align: center;
            font-size: 10px;
            transition: all var(--transition);
        }
        .achievement-card.unlocked { border-color: var(--yellow); background: #f0c04010; }
        .achievement-card.locked { opacity: 0.5; }
        .achievement-card .ach-icon { font-size: 28px; margin-bottom: 4px; }
        .achievement-card .ach-name { font-weight: 700; }
        
        /* ========== RESPONSIVE DESIGN ========== */
        @media (max-width: 800px) {
            .main-layout { flex-direction: column; }
            .sidebar {
                width: 100%;
                min-width: unset;
                position: static;
                max-height: unset;
                flex-direction: row;
                flex-wrap: wrap;
                justify-content: center;
                padding: 8px;
                gap: 2px;
            }
            .sidebar .user-card { width: 100%; }
