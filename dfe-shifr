        function addToHistorySilent(entry) {
            entry.timestamp = new Date().toISOString();
            entry.id = Date.now();
            // Don't duplicate consecutive identical entries
            if (state.history.length > 0 &&
                state.history[0].from === entry.from &&
                state.history[0].to === entry.to) {
                return;
            }
            state.history.unshift(entry);
            if (state.history.length > state.settings.historyLimit) {
                state.history.pop();
            }
            renderHistoryList();
            saveStateToStorage();
        }
        
