        function rebuildAllDictionaries() {
            allToDfe = {
                ...ruToDfe,
                ...enToDfe,
                ...digitsToDfe,
                ...symbolsToDfe
            };
            dfeToChar = {};
            for (const [char, code] of Object.entries(allToDfe)) {
                dfeToChar[code] = char;
            }
            sortedCodes = Object.keys(dfeToChar).sort((a, b) => b.length - a.length);
        }
